rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /collections/{collectionId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && (request.auth.token.email == 'ayushclasses10@gmail.com' || request.auth.token.email.lower() == 'shreeparevajewellers@gmail.com');
    }

    match /jewelries/{jewelleryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && (request.auth.token.email == 'ayushclasses10@gmail.com' || request.auth.token.email.lower() == 'shreeparevajewellers@gmail.com');
    }

    match /heroBanners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && (request.auth.token.email == 'ayushclasses10@gmail.com' || request.auth.token.email.lower() == 'shreeparevajewellers@gmail.com');
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && (request.auth.token.email == 'ayushclasses10@gmail.com' || request.auth.token.email.lower() == 'shreeparevajewellers@gmail.com');
    }
  }
}
