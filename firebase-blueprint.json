{
  "entities": {
    "Jewellery": {
      "title": "Jewellery Item",
      "description": "A single piece of jewellery for sale or display.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "collectionId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "price": { "type": "number", "description": "Optional price" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "description", "collectionId", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "/jewelries/{jewelleryId}": {
      "schema": "Jewellery",
      "description": "Stores individual jewellery items."
    }
  }
}
